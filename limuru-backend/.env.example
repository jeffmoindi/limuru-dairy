# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5500

# Database (PostgreSQL)
DATABASE_URL=postgres://limuru_user:changeme@localhost:5432/limuru_dairy

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=8h

# Admin bootstrap (used once by db/seed.js to create the first admin account)
ADMIN_EMAIL=admin@limurudairy.co.ke
ADMIN_PASSWORD=changeme_strong_password

# Email (optional — used to notify staff of new appointments/applications/messages)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=hello@limurudairy.co.ke
